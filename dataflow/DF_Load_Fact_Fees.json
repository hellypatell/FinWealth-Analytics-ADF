{
	"name": "DF_Load_Fact_Fees",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_Stg_Fees",
						"type": "DatasetReference"
					},
					"name": "SourceFees"
				},
				{
					"dataset": {
						"referenceName": "DS_Dim_Accounts",
						"type": "DatasetReference"
					},
					"name": "sourceAccount"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Fact_Fees",
						"type": "DatasetReference"
					},
					"name": "SinkFactFees"
				}
			],
			"transformations": [
				{
					"name": "FilterNulls"
				},
				{
					"name": "DerivedFees"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          FeeID as string,",
				"          AccountID as string,",
				"          FeeDate as date,",
				"          FeeType as string,",
				"          Amount as decimal(18,2),",
				"          stg_load_date as timestamp,",
				"          stg_source_file as string,",
				"          stg_batch_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceFees",
				"source(output(",
				"          account_sk as integer,",
				"          account_id as string,",
				"          client_id as string,",
				"          account_type as string,",
				"          open_date as date,",
				"          base_currency as string,",
				"          status as string,",
				"          is_current as boolean,",
				"          dwh_created_date as timestamp,",
				"          dwh_updated_date as timestamp,",
				"          CurrencyGroup as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourceAccount",
				"SourceFees filter(!isNull(FeeID) && !isNull(AccountID) && !isNull(Amount)) ~> FilterNulls",
				"FilterNulls derive(fee_date_sk = toInteger(toString(FeeDate, 'yyyyMMdd')),",
				"          dwh_load_date = currentTimestamp(),",
				"          batch_id = 'ADF_DF_RUN') ~> DerivedFees",
				"DerivedFees, sourceAccount lookup(AccountID  == account_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 select(mapColumn(",
				"          FeeID,",
				"          FeeDate,",
				"          FeeType,",
				"          Amount,",
				"          fee_date_sk,",
				"          account_sk,",
				"          batch_id,",
				"          dwh_load_date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          fee_sk as long,",
				"          fee_id as string,",
				"          account_sk as integer,",
				"          fee_date_sk as integer,",
				"          fee_type as string,",
				"          fee_amount as decimal(18,2),",
				"          dwh_load_date as timestamp,",
				"          batch_id as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fee_id = FeeID,",
				"          account_sk,",
				"          fee_date_sk,",
				"          fee_type = FeeType,",
				"          fee_amount = Amount,",
				"          batch_id,",
				"          dwh_load_date",
				"     )) ~> SinkFactFees"
			]
		}
	}
}